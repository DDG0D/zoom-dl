# ═══════════════════════════════════════════════════════
#   ZOOM DOWNLOADER — .gitignore
# ═══════════════════════════════════════════════════════

# ─── Downloads & output ───────────────────────────────
downloads/
*.mp4
video_url.txt

# ─── Secrets & credentials ────────────────────────────
.env
*.pem
*.key

# ─── Debug artifacts ──────────────────────────────────
screenshot_error.png
recon.py
recon_output*.json

# ─── Internal / planning docs ─────────────────────────
IGNORE_FOLDER_ZOOM/

# ─── Legacy scripts (hardcoded URLs) ─────────────────
download_zoom.py

# ─── User data ────────────────────────────────────────
urls.txt

# ─── Python ───────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
dist/
build/
.eggs/
*.whl
pip-log.txt
pip-delete-this-directory.txt

# ─── Virtual environments ─────────────────────────────
venv/
.venv/
env/
ENV/

# ─── Testing ──────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# ─── OS ───────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# ─── IDE / editors ────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/
