# ═══════════════════════════════════════════════════════
#   ZOOM DOWNLOADER — Configuration
# ═══════════════════════════════════════════════════════
#
#   Copy this file to .env and customize:
#     cp .env.example .env
#
#   All values below are defaults. Uncomment and
#   change only what you need.
# ═══════════════════════════════════════════════════════

# ─── Download ─────────────────────────────────────────

# Download mode: "sequential" (one at a time) or "parallel"
# DOWNLOAD_MODE=sequential

# Max simultaneous downloads in parallel mode (1–10)
# MAX_PARALLEL=3

# Output directory for recordings
# DOWNLOAD_DIR=./downloads

# Skip files that already exist locally (true/false)
# SKIP_EXISTING=true

# ─── Proxy ────────────────────────────────────────────
# HTTP proxy — useful for bypassing CAPTCHA / Cloudflare
# Supports: http://host:port  or  http://user:pass@host:port
#
# Examples:
#   PROXY=http://127.0.0.1:8080
#   PROXY=http://user:pass@proxy.example.com:3128
#   PROXY=http://rotating-proxy.service.com:9000
#
# You can also set this interactively:  /proxy
# PROXY=

# ─── Capture ─────────────────────────────────────────
# Use Playwright browser instead of pure HTTP (slower but
# works when HTTP capture is blocked)
# USE_BROWSER=false

# Run browser in headless mode (true/false)
# HEADLESS=true

# ─── Timeouts (seconds) ──────────────────────────────

# Time to wait for Zoom pages to load
# PAGE_LOAD_TIMEOUT=30

# Max time for a single file download (default: 30 min)
# DOWNLOAD_TIMEOUT=1800

# ─── Retry ───────────────────────────────────────────

# Number of retry attempts on failure
# MAX_RETRIES=3

# Delay between retries in seconds (multiplied by attempt #)
# RETRY_DELAY=5

# ─── Logging ─────────────────────────────────────────
# Options: DEBUG, INFO, WARNING, ERROR
# LOG_LEVEL=INFO
